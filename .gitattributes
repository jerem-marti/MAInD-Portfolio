# Normalize line endings: store text as LF in the repo and check it out as LF,
# so Git stops warning "LF will be replaced by CRLF" on Windows. Binaries are
# auto-detected by `text=auto` and left byte-for-byte (the explicit rules below
# are belt-and-suspenders for the asset types this repo carries).
* text=auto eol=lf

# Images
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.avif  binary
*.ico   binary
*.svg   text eol=lf

# Documents
*.pdf   binary

# Fonts
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary

# Media
*.mp4   binary
*.webm  binary
*.mov   binary
