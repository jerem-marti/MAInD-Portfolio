# Nuxt dev/build outputs
.output
.data
.nuxt
.nitro
.cache
dist

# Node dependencies
node_modules

# Logs
logs
*.log

# Misc
.DS_Store
Thumbs.db
.fleet
.idea
.vscode

# Local tooling
.claude
*.local

# Working docs under docs/superpowers/: scratch (notes, drafts) stays local;
# design specs and implementation plans are tracked, so they never need force-adding.
docs/superpowers/*
!docs/superpowers/specs/
!docs/superpowers/plans/

# Owner-only local working docs (e.g. French-translation journals) — kept out of the repo
docs/_local/

# Local env files
.env
.env.*
!.env.example
